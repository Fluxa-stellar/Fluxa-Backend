generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  role     UserRole @default(BUSINESS_USER)

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Business {
  id      String @id @default(uuid())
  name    String
  country String

  kycStatus KYCStatus @default(PENDING)

  users        User[]
  wallets      Wallet[]
  transactions Transaction[]
  invoices     Invoice[]

  createdAt DateTime @default(now())
}

model Wallet {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  currency CurrencyType
  balance  Decimal      @default(0)

  stellarAddress String? // USDC on Stellar wallet

  createdAt DateTime @default(now())
}

model Transaction {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  type     TransactionType
  amount   Decimal
  currency CurrencyType

  status TransactionStatus @default(PENDING)

  reference String? // Stellar tx hash or bank ref

  metadata Json?

  createdAt DateTime @default(now())
}

model FxRate {
  id String @id @default(uuid())

  from CurrencyType
  to   CurrencyType

  rate Decimal

  source String

  createdAt DateTime @default(now())
}

model Invoice {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  clientName String
  amount     Decimal
  currency   CurrencyType

  status InvoiceStatus @default(PENDING)

  dueDate DateTime?

  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  BUSINESS_USER
  ACCOUNTANT
  VIEWER
}

enum CurrencyType {
  USD
  EUR
  GBP
  NGN
  KES
  GHS
  ZAR
  USDC
  USDT
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  CONVERSION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum KYCStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}
